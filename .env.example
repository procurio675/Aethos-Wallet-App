# ==========================================
# Root Environment Variables Template
# ==========================================
# Copy this file to .env and fill in the values.
# The monorepo apps will read from the root .env or their own .env files.

# 1. Database (Neon PostgreSQL)
# Used by packages/db and all apps that query the database
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# 2. NextAuth Secret (user-app)
# Generate a secret using: openssl rand -base64 32
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# 3. Microservice URLs
# The URL of the mock bank (used by the sweeper)
MOCK_BANK_URL="http://localhost:3001"
# The webhook handler URL (used by the mock bank)
WEBHOOK_HANDLER_URL="http://localhost:3002/webhook"

# 4. Sweeper Configuration
# How often the background worker runs (in milliseconds)
POLL_INTERVAL_MS=5000
