# Required — Neon PostgreSQL connection string
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# URL of the mock bank for status queries and outbound transfers
MOCK_BANK_URL="http://localhost:3001"

# How often the sweeper runs (milliseconds)
POLL_INTERVAL_MS=5000

# Shared secret for signing payout requests to the bank (HMAC-SHA256)
# Must match the same secret configured in the mock-bank and webhook-handler
BANK_WEBHOOK_SECRET="your-shared-secret-here"

# Secret for authenticating reconciliation queries to the bank's transaction-status endpoint
SWEEPER_SECRET="your-sweeper-secret-here"
